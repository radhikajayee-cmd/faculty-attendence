rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: any authenticated user can read any user doc (needed for admin),
    // but can only write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Attendance collection: any authenticated user can read and write.
    // Faculty needs to read/write their own records; admin needs to read all.
    match /attendance/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
